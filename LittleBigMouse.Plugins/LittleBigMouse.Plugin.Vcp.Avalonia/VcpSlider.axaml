<UserControl x:Class="LittleBigMouse.Plugin.Vcp.Avalonia.VcpSlider"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:avalonia="clr-namespace:LittleBigMouse.Plugin.Vcp.Avalonia"
             xmlns:controls="clr-namespace:HLab.Base.Avalonia.Controls;assembly=HLab.Base.Avalonia"
             mc:Ignorable="d"
             d:DesignHeight="220"
             x:Name="UserControl"
             x:DataType="avalonia:VcpSliderViewModel"
             >

    <Design.DataContext>
            <avalonia:VcpSliderViewModelDesign/>
        </Design.DataContext>

    <UserControl.Styles>
        <!-- DoubleBox's template right-aligns its inner TextBox; the chip wants
             the value centered -->
        <Style Selector="controls|DoubleBox /template/ TextBox#PART_TextBox">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <!-- One fader column: vertical slider, value chip underneath -->
    <StackPanel Width="64">

        <Slider
            x:Name="LevelSlider"
            Height="120"
            HorizontalAlignment="Center"
            Orientation="Vertical"

            IsEnabled="{Binding Model.Enabled}"

            SmallChange="1"
            LargeChange="10"
            Value="{Binding Model.Value}"
            Minimum="{Binding Model.Min}"
            Maximum="{Binding Model.Max}"

            TickFrequency="10"
            TickPlacement="None"

            PointerWheelChanged="OnPointerWheelChanged"
            />

        <!-- Value chip: editable, wheel = ±1, amber while the DDC write is in flight -->
        <Border Width="48" Height="26"
                Margin="0,6,0,0"
                HorizontalAlignment="Center"
                CornerRadius="6"
                BorderThickness="1"
                BorderBrush="#30808080"
                Background="{Binding ChipBackground}">
            <controls:DoubleBox
                BorderThickness="0"
                Background="Transparent"
                Foreground="{DynamicResource HLab.Brushes.Foreground}"
                FontSize="12"
                Padding="0"
                Decimals="0"
                Value="{Binding Model.Value}"
                PointerWheelChanged="OnPointerWheelChanged"
                VerticalAlignment="Center"
                HorizontalAlignment="Stretch"
                />
        </Border>

    </StackPanel>
</UserControl>
